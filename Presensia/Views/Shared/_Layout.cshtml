@{
    var year = DateTime.UtcNow.Year;
    var title = ViewData["Title"] as string ?? "Presensia — AG sans stress";
}
<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Using system font stack or place local fonts in /wwwroot/fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="py-3 border-bottom border-white border-opacity-25 bg-opacity">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="~/img/logo-presensia.png" alt="Presensia" width="36" height="36" class="rounded-circle border border-0">
                <div>
                    <div class="fw-semibold">Presensia</div>
                    <small class="text-white-50">Assemblées Générales</small>
                </div>
            </div>
            <nav class="d-flex gap-2">
                <!-- <button id="themeToggle" class="btn btn-sm btn-outline-secondary">Theme</button>-->
                <button class="btn btn-sm btn-outline-info" data-tab="ux">Expérience (UX/UI)</button>
                <button class="btn btn-sm btn-outline-info" data-tab="compliance">Compliance &amp; DSI</button>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="border-top border-white border-opacity-25 py-4">
        <div class="container d-flex flex-column flex-md-row justify-content-between small text-white-50">
            <div>© @year Presensia — une solution Satellisoft</div>
            <div class="d-flex gap-3">
                <a href="#" class="link-light link-underline-opacity-0">Mentions légales</a>
                <a href="#" class="link-light link-underline-opacity-0">Contrat &amp; SLA</a>
                <a href="#" class="link-light link-underline-opacity-0">Politique RGPD</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>